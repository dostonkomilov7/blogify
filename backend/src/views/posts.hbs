<!DOCTYPE html>
<html lang="uz">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Posts — Lenta</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap"
    rel="stylesheet" />
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg: #0d0d0f;
      --surface: #15151a;
      --border: #252530;
      --accent: #e8c97e;
      --accent2: #c9a44e;
      --text: #e8e6e0;
      --muted: #7a7880;
      --danger: #c96b6b;
      --radius: 14px;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
    }

    /* ── NAV ── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(13, 13, 15, .85);
      backdrop-filter: blur(18px);
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
    }

    .nav-brand {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem;
      letter-spacing: .04em;
      color: var(--accent);
    }

    .nav-actions {
      display: flex;
      gap: .75rem;
      align-items: center;
    }

    .btn {
      cursor: pointer;
      border: none;
      font-family: inherit;
      font-size: .875rem;
      border-radius: 8px;
      padding: .55rem 1.2rem;
      font-weight: 500;
      transition: all .2s;
    }

    .btn-ghost {
      background: transparent;
      color: var(--muted);
      border: 1px solid var(--border);
    }

    .btn-ghost:hover {
      color: var(--text);
      border-color: var(--muted);
    }

    .btn-primary {
      background: var(--accent);
      color: #0d0d0f;
    }

    .btn-primary:hover {
      background: var(--accent2);
    }

    /* ── HERO ── */
    .hero {
      text-align: center;
      padding: 80px 2rem 60px;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(232, 201, 126, .12) 0%, transparent 70%);
      pointer-events: none;
    }

    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.4rem, 6vw, 4.5rem);
      line-height: 1.1;
      letter-spacing: -.01em;
      margin-bottom: 1rem;
    }

    .hero h1 em {
      font-style: italic;
      color: var(--accent);
    }

    .hero p {
      color: var(--muted);
      font-size: 1.05rem;
      max-width: 480px;
      margin: 0 auto 2rem;
    }

    .hero-stats {
      display: inline-flex;
      gap: 2.5rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: .6rem 2rem;
      font-size: .8rem;
      color: var(--muted);
    }

    .hero-stats span strong {
      color: var(--text);
      font-size: 1rem;
      margin-right: .25rem;
    }

    /* ── TOOLBAR ── */
    .toolbar {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 2rem 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .search-wrap {
      flex: 1;
      min-width: 220px;
      position: relative;
    }

    .search-wrap svg {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      opacity: .4;
    }

    .search-wrap input {
      width: 100%;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      color: var(--text);
      font-family: inherit;
      font-size: .9rem;
      padding: .65rem 1rem .65rem 2.6rem;
      outline: none;
      transition: border-color .2s;
    }

    .search-wrap input:focus {
      border-color: var(--accent);
    }

    .filter-tabs {
      display: flex;
      gap: .4rem;
    }

    .filter-tab {
      cursor: pointer;
      background: transparent;
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--muted);
      font-family: inherit;
      font-size: .8rem;
      padding: .5rem 1rem;
      transition: all .2s;
    }

    .filter-tab.active,
    .filter-tab:hover {
      background: var(--accent);
      color: #0d0d0f;
      border-color: var(--accent);
      font-weight: 500;
    }

    /* ── GRID ── */
    .grid {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 2rem 4rem;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1.5rem;
    }

    /* ── CARD ── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      transition: transform .25s, border-color .25s, box-shadow .25s;
      animation: fadeUp .5s ease both;
    }

    .card:hover {
      transform: translateY(-4px);
      border-color: rgba(232, 201, 126, .35);
      box-shadow: 0 20px 48px rgba(0, 0, 0, .5), 0 0 0 1px rgba(232, 201, 126, .1);
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* stagger children */
    .card:nth-child(1) {
      animation-delay: .05s
    }

    .card:nth-child(2) {
      animation-delay: .10s
    }

    .card:nth-child(3) {
      animation-delay: .15s
    }

    .card:nth-child(4) {
      animation-delay: .20s
    }

    .card:nth-child(5) {
      animation-delay: .25s
    }

    .card:nth-child(6) {
      animation-delay: .30s
    }

    .card-media {
      position: relative;
      overflow: hidden;
      background: #1a1a22;
    }

    .card-media img {
      width: 100%;
      aspect-ratio: 16/9;
      object-fit: cover;
      display: block;
      transition: transform .4s ease;
    }

    .card:hover .card-media img {
      transform: scale(1.04);
    }

    .card-media.no-img {
      aspect-ratio: 16/9;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .card-media.no-img svg {
      opacity: .15;
    }

    .video-badge {
      position: absolute;
      top: 10px;
      right: 10px;
      background: rgba(0, 0, 0, .7);
      color: var(--accent);
      border: 1px solid rgba(232, 201, 126, .3);
      border-radius: 6px;
      padding: .25rem .55rem;
      font-size: .7rem;
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: .3rem;
      backdrop-filter: blur(8px);
    }

    .card-body {
      padding: 1.25rem 1.25rem 1rem;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .card-meta {
      display: flex;
      align-items: center;
      gap: .6rem;
      margin-bottom: .85rem;
    }

    .avatar {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: .7rem;
      font-weight: 700;
      color: #0d0d0f;
      flex-shrink: 0;
    }

    .meta-info {
      display: flex;
      flex-direction: column;
      gap: .1rem;
    }

    .meta-author {
      font-size: .78rem;
      color: var(--text);
      font-weight: 500;
    }

    .meta-date {
      font-size: .72rem;
      color: var(--muted);
    }

    .card-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.15rem;
      line-height: 1.35;
      margin-bottom: .6rem;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .card-content {
      font-size: .875rem;
      color: var(--muted);
      line-height: 1.6;
      flex: 1;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .card-footer {
      padding: .85rem 1.25rem;
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: .5rem;
    }

    .card-actions {
      display: flex;
      gap: .4rem;
    }

    .icon-btn {
      cursor: pointer;
      background: transparent;
      border: 1px solid var(--border);
      border-radius: 7px;
      color: var(--muted);
      padding: .4rem .55rem;
      font-size: .75rem;
      display: flex;
      align-items: center;
      gap: .3rem;
      transition: all .18s;
      font-family: inherit;
    }

    .icon-btn:hover {
      color: var(--text);
      border-color: var(--muted);
    }

    .icon-btn.edit:hover {
      color: var(--accent);
      border-color: var(--accent);
    }

    .icon-btn.del:hover {
      color: var(--danger);
      border-color: var(--danger);
    }

    .read-link {
      font-size: .8rem;
      color: var(--accent);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: .3rem;
      transition: gap .2s;
    }

    .read-link:hover {
      gap: .5rem;
    }

    /* ── EMPTY STATE ── */
    .empty {
      grid-column: 1/-1;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 5rem 2rem;
      color: var(--muted);
      gap: 1rem;
      text-align: center;
    }

    .empty svg {
      opacity: .2;
    }

    .empty h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem;
      color: var(--text);
    }

    /* ── MODAL BACKDROP ── */
    .modal-backdrop {
      position: fixed;
      inset: 0;
      z-index: 200;
      background: rgba(0, 0, 0, .7);
      backdrop-filter: blur(6px);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
      opacity: 0;
      pointer-events: none;
      transition: opacity .25s;
    }

    .modal-backdrop.open {
      opacity: 1;
      pointer-events: all;
    }

    .modal {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 18px;
      width: 100%;
      max-width: 540px;
      transform: translateY(20px);
      transition: transform .25s;
      overflow: hidden;
    }

    .modal-backdrop.open .modal {
      transform: translateY(0);
    }

    .modal-header {
      padding: 1.25rem 1.5rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .modal-header h2 {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
    }

    .modal-body {
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: .4rem;
    }

    .form-group label {
      font-size: .8rem;
      color: var(--muted);
      font-weight: 500;
      letter-spacing: .04em;
      text-transform: uppercase;
    }

    .form-group input,
    .form-group textarea {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 9px;
      color: var(--text);
      font-family: inherit;
      font-size: .9rem;
      padding: .7rem 1rem;
      outline: none;
      transition: border-color .2s;
      resize: vertical;
    }

    .form-group input:focus,
    .form-group textarea:focus {
      border-color: var(--accent);
    }

    .form-group textarea {
      min-height: 100px;
    }

    .modal-footer {
      padding: 1rem 1.5rem;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: flex-end;
      gap: .6rem;
    }

    /* ── TOAST ── */
    .toast {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      z-index: 999;
      background: var(--surface);
      border: 1px solid var(--accent);
      border-radius: 10px;
      padding: .8rem 1.4rem;
      font-size: .875rem;
      display: flex;
      align-items: center;
      gap: .6rem;
      box-shadow: 0 8px 32px rgba(0, 0, 0, .5);
      transform: translateY(80px);
      opacity: 0;
      transition: all .3s cubic-bezier(.34, 1.56, .64, 1);
    }

    .toast.show {
      transform: translateY(0);
      opacity: 1;
    }

    /* scrollbar */
    ::-webkit-scrollbar {
      width: 6px;
    }

    ::-webkit-scrollbar-track {
      background: var(--bg);
    }

    ::-webkit-scrollbar-thumb {
      background: var(--border);
      border-radius: 3px;
    }
  </style>
</head>

<body>

  <!-- NAV -->
  <nav>
    <span class="nav-brand">✦ Lenta</span>
    <div class="nav-actions">
      <button class="btn btn-ghost">Kirish</button>
      <button class="btn btn-primary" onclick="openModal()">+ Yangi post</button>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <h1>Barcha <em>postlar</em><br>bir joyda</h1>
    <p>Eng so'nggi maqolalar, yangiliklar va multimedia kontentlar</p>
    <div class="hero-stats">
      <span><strong>{{totalPosts}}</strong> post</span>
      <span><strong>{{totalUsers}}</strong> muallif</span>
      <span><strong>{{mediaCount}}</strong> media fayl</span>
    </div>
  </section>

  <!-- TOOLBAR -->
  <div class="toolbar">
    <div class="search-wrap">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="8" />
        <path d="m21 21-4.35-4.35" />
      </svg>
      <input type="text" placeholder="Post qidirish..." oninput="filterPosts(this.value)" />
    </div>
    <div class="filter-tabs">
      <button class="filter-tab active" onclick="setFilter('all',this)">Barchasi</button>
      <button class="filter-tab" onclick="setFilter('media',this)">📸 Mediali</button>
      <button class="filter-tab" onclick="setFilter('video',this)">🎬 Videoli</button>
      <button class="filter-tab" onclick="setFilter('text',this)">📝 Matnli</button>
    </div>
  </div>

  <!-- GRID -->
  <main class="grid" id="postsGrid">

    {{#if posts.length}}
    {{#each posts}}
    <article class="card" data-id="{{_id}}" data-has-media="{{#if image_url}}true{{else}}false{{/if}}"
      data-has-video="{{#if video_url}}true{{else}}false{{/if}}">
      <!-- MEDIA -->
      {{#if image_url}}
      <div class="card-media">
        <img src="{{image_url}}" alt="{{title}}" loading="lazy"
          onerror="this.closest('.card-media').innerHTML='<div style=\'height:180px;display:flex;align-items:center;justify-content:center;opacity:.2\'>Rasm yuklanmadi</div>'" />
        {{#if video_url}}
        <span class="video-badge">
          <svg width="10" height="10" fill="currentColor" viewBox="0 0 24 24">
            <polygon points="5 3 19 12 5 21" />
          </svg>
          Video
        </span>
        {{/if}}
      </div>
      {{else}}
      <div class="card-media no-img">
        <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <rect x="3" y="3" width="18" height="18" rx="3" />
          <circle cx="8.5" cy="8.5" r="1.5" />
          <polyline points="21 15 16 10 5 21" />
        </svg>
      </div>
      {{/if}}

      <!-- BODY -->
      <div class="card-body">
        <div class="card-meta">
          <div class="avatar">{{created_by.initials}}</div>
          <div class="meta-info">
            <span class="meta-author">{{created_by.username}}</span>
            <span class="meta-date">{{formatDate createdAt}}</span>
          </div>
        </div>
        <h2 class="card-title">{{title}}</h2>
        {{#if content}}
        <p class="card-content">{{content}}</p>
        {{/if}}
      </div>

      <!-- FOOTER -->
      <div class="card-footer">
        <div class="card-actions">
          <button class="icon-btn edit" onclick="editPost('{{_id}}','{{title}}','{{content}}')">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
            </svg>
            Tahrir
          </button>
          <button class="icon-btn del" onclick="deletePost('{{_id}}')">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <polyline points="3 6 5 6 21 6" />
              <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" />
            </svg>
            O'chir
          </button>
        </div>
        <a href="/posts/{{_id}}" class="read-link">
          O'qish
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </div>
    </article>
    {{/each}}
    {{else}}
    <div class="empty">
      <svg width="64" height="64" fill="none" stroke="currentColor" stroke-width="1.2" viewBox="0 0 24 24">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
        <polyline points="14 2 14 8 20 8" />
        <line x1="16" y1="13" x2="8" y2="13" />
        <line x1="16" y1="17" x2="8" y2="17" />
        <polyline points="10 9 9 9 8 9" />
      </svg>
      <h3>Hozircha postlar yo'q</h3>
      <p>Birinchi bo'lib post yarating!</p>
      <button class="btn btn-primary" onclick="openModal()">+ Yangi post</button>
    </div>
    {{/if}}

  </main>

  <!-- CREATE / EDIT MODAL -->
  <div class="modal-backdrop" id="modalBackdrop" onclick="closeOnBackdrop(event)">
    <div class="modal">
      <div class="modal-header">
        <h2 id="modalTitle">Yangi post</h2>
        <button class="icon-btn" onclick="closeModal()">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="postId" />
        <div class="form-group">
          <label>Sarlavha *</label>
          <input type="text" id="title" placeholder="Kamida 4 ta belgi..." />
        </div>
        <div class="form-group">
          <label>Matn</label>
          <textarea id="postContent" placeholder="Post mazmuni (kamida 10 belgi)..."></textarea>
        </div>
        <div class="form-group">
          <label>Rasm URL</label>
          <input type="url" id="postImageUrl" placeholder="https://example.com/image.jpg" />
        </div>
        <div class="form-group">
          <label>Video URL</label>
          <input type="url" id="postVideoUrl" placeholder="https://youtube.com/..." />
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-ghost" onclick="closeModal()">Bekor qilish</button>
        <button class="btn btn-primary" onclick="submitPost()">Saqlash</button>
      </div>
    </div>
  </div>

  <!-- TOAST -->
  <div class="toast" id="toast">
    <span id="toastIcon">✓</span>
    <span id="toastMsg">Saqlandi!</span>
  </div>

  <script>
    /* ── MODAL ── */
    function openModal() { document.getElementById('modalBackdrop').classList.add('open'); }
    function closeModal() { document.getElementById('modalBackdrop').classList.remove('open'); resetModal(); }
    function closeOnBackdrop(e) { if (e.target === e.currentTarget) closeModal(); }

    function resetModal() {
      ['postId', 'postTitle', 'postContent', 'postImageUrl', 'postVideoUrl'].forEach(id => document.getElementById(id).value = '');
      document.getElementById('modalTitle').textContent = 'Yangi post';
    }

    function editPost(id, title, content) {
      document.getElementById('modalTitle').textContent = 'Postni tahrirlash';
      document.getElementById('postId').value = id;
      document.getElementById('postTitle').value = title || '';
      document.getElementById('postContent').value = content || '';
      openModal();
    }

    function submitPost() {
      const title = document.getElementById('postTitle').value.trim();
      if (title.length < 4) { showToast('Sarlavha kamida 4 ta belgi!', '✗', true); return; }
      const id = document.getElementById('postId').value;
      const method = id ? 'PUT' : 'POST';
      const url = id ? `/api/posts/${id}` : '/api/posts';
      fetch(url, {
        method, headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          title,
          content: document.getElementById('postContent').value,
          image_url: document.getElementById('postImageUrl').value,
          video_url: document.getElementById('postVideoUrl').value,
        })
      })
        .then(r => { if (!r.ok) throw new Error(); return r.json(); })
        .then(() => { showToast(id ? 'Post yangilandi!' : 'Post yaratildi!'); closeModal(); setTimeout(() => location.reload(), 900); })
        .catch(() => showToast('Xatolik yuz berdi', '✗', true));
    }

    function deletePost(id) {
      if (!confirm('Postni o\'chirishni tasdiqlaysizmi?')) return;
      fetch(`/api/posts/${id}`, { method: 'DELETE' })
        .then(r => { if (!r.ok) throw new Error(); })
        .then(() => { showToast('Post o\'chirildi'); setTimeout(() => location.reload(), 900); })
        .catch(() => showToast('Xatolik yuz berdi', '✗', true));
    }

    /* ── SEARCH & FILTER ── */
    let currentFilter = 'all';
    function filterPosts(q) {
      q = q.toLowerCase();
      document.querySelectorAll('.card').forEach(c => {
        const title = c.querySelector('.card-title')?.textContent.toLowerCase() || '';
        const pass = title.includes(q) && matchesFilter(c);
        c.style.display = pass ? '' : 'none';
      });
    }
    function matchesFilter(card) {
      if (currentFilter === 'all') return true;
      if (currentFilter === 'media') return card.dataset.hasMedia === 'true';
      if (currentFilter === 'video') return card.dataset.hasVideo === 'true';
      if (currentFilter === 'text') return card.dataset.hasMedia === 'false' && card.dataset.hasVideo === 'false';
      return true;
    }
    function setFilter(f, btn) {
      currentFilter = f;
      document.querySelectorAll('.filter-tab').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      filterPosts(document.querySelector('.search-wrap input').value);
    }

    /* ── TOAST ── */
    let toastTimer;
    function showToast(msg, icon = '✓', err = false) {
      const t = document.getElementById('toast');
      document.getElementById('toastMsg').textContent = msg;
      document.getElementById('toastIcon').textContent = icon;
      t.style.borderColor = err ? 'var(--danger)' : 'var(--accent)';
      t.classList.add('show');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => t.classList.remove('show'), 2800);
    }
  </script>
</body>

</html>